# FounderOps Environment Variables Example
# Copy this file to .env.local and fill in your actual values

# Supabase Configuration
# Get these from your Supabase project settings
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Stripe Configuration
# Get these from your Stripe dashboard
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Stripe Connect OAuth
# Set up in Stripe Connect settings
STRIPE_CLIENT_ID=ca_your-stripe-connect-client-id
STRIPE_CONNECT_REDIRECT_URI=https://your-app.com/api/stripe/callback

# App Configuration
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_API_URL=https://your-api.com

# Optional: Analytics & Monitoring
EXPO_PUBLIC_SENTRY_DSN=your-sentry-dsn
EXPO_PUBLIC_ANALYTICS_ID=your-analytics-id